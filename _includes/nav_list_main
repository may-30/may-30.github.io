<!--전체 글 수를 세기 위한 연산. sum 변수에 전체 글 수 저장-->

{% assign sum = site.posts | size %}

<nav class="nav__list">
  <input id="ac-toc" name="accordion-toc" type="checkbox" />
  <label for="ac-toc">{{ site.data.ui-text[site.locale].menu_label }}</label>
  <ul class="nav__items" id="category_tag_menu">
      <!--전체 글 수-->
      <li>
            <span class="nav__sub-title">전체 글 수 {{sum}} 개</span>
      </li>
      <li>
        <!--span 태그로 카테고리들을 크게 분류 terraform -->
        <span class="nav__sub-title">terraform</span>
            <!--ul 태그로 같은 카테고리들 모아둔 페이지들 나열-->
            <ul>
                <!--terraform-error 카테고리 글들을 모아둔 페이지인 /categories/terraform-error 주소의 글로 링크 연결-->
                <!--category[1].size 로 해당 카테고리를 가진 글의 개수 표시--> 
                {% for category in site.categories %}
                    {% if category[0] == "terraform error" %}
                        <li><a href="/categories/terraform-error" class="">error ({{category[1].size}})</a></li>
                    {% endif %}
                {% endfor %}
            </ul>
            <ul>
                <!--terraform-lab 카테고리 글들을 모아둔 페이지인 /categories/terraform-lab 주소의 글로 링크 연결-->
                <!--category[1].size 로 해당 카테고리를 가진 글의 개수 표시--> 
                {% for category in site.categories %}
                    {% if category[0] == "terraform lab" %}
                        <li><a href="/categories/terraform-lab" class="">lab ({{category[1].size}})</a></li>
                    {% endif %}
                {% endfor %}
            </ul>
        
        <!--span 태그로 카테고리들을 크게 분류 golang -->
        <span class="nav__sub-title">golang</span>
            <!--ul 태그로 같은 카테고리들 모아둔 페이지들 나열-->
            <ul>
                <!--golang 카테고리 글들을 모아둔 페이지인 /categories/golang 주소의 글로 링크 연결-->
                <!--category[1].size 로 해당 카테고리를 가진 글의 개수 표시--> 
                {% for category in site.categories %}
                    {% if category[0] == "golang" %}
                        <li><a href="/categories/golang" class="">golang ({{category[1].size}})</a></li>
                    {% endif %}
                {% endfor %}
            </ul>
      </li>
  </ul>
</nav>